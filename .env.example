# ─────────────────────────────────────────────────
#  Katy AI by Makoy — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Frontend URL (used for CORS — set to your actual domain)
FRONTEND_URL=https://makoy.org

# ─── Hostinger SMTP (Email) ───────────────────────
# Hostinger email settings for team@makoy.org
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=team@makoy.org
SMTP_PASS=your_email_password_here

# ─── Hostinger MySQL (Database) ───────────────────
# Found in Hostinger hPanel → Databases → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_username
DB_PASS=your_db_password
DB_NAME=makoy

# ─────────────────────────────────────────────────
# Notes:
#   SMTP
#     - SMTP_PORT 465 = SSL (recommended for Hostinger)
#     - SMTP_PORT 587 = TLS (alternative)
#     - Never commit the actual .env file to git
#     - SMTP_PASS is your Hostinger email account password
#
#   MySQL
#     - On Hostinger: hPanel → Databases → MySQL Databases
#     - Create a database and user, grant all privileges
#     - DB_HOST is usually 'localhost' on shared hosting
#     - The leads table is created automatically on first start
#
#   Marketing leads table columns (for reference):
#     email (PK), first_name, last_name, company, company_size,
#     industry, job_title, country, hr_challenge, notes,
#     phone, linkedin_url, source, utm_source, utm_medium,
#     utm_campaign, email_verified, opted_in_at, verified_at,
#     consulted_at, created_at, updated_at
# ─────────────────────────────────────────────────
