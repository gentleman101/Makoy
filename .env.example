# ─────────────────────────────────────────────────
#  Katy AI by Makoy — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# URLs
SITE_URL=https://makoy.org
API_URL=https://api.makoy.org

# ─── Hostinger SMTP (Email) ───────────────────────
# Hostinger email settings for team@makoy.org
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=team@makoy.org
SMTP_PASS=your_email_password_here

# Who receives consultation form submissions
TEAM_EMAIL=team@makoy.org

# ─────────────────────────────────────────────────
# Notes:
#   SMTP
#     - SMTP_PORT 465 = SSL (recommended for Hostinger)
#     - SMTP_PORT 587 = TLS (alternative)
#     - Never commit the actual .env file to git
#     - SMTP_PASS is your Hostinger email account password
#
#   SQLite
#     - DB is stored in ./data/makoy.db inside the container
#     - The data/ folder is volume-mounted so it persists across rebuilds
#     - No separate DB setup needed — tables are created automatically
#
#   Magic link flow
#     - User submits email → POST /send-link → magic link emailed
#     - User clicks link → GET /verify → redirected to SITE_URL?unlocked=1
#     - Frontend detects ?unlocked=1 and unlocks resources
# ─────────────────────────────────────────────────
