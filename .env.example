# ─────────────────────────────────────────────────
#  Katy AI by Makoy — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Frontend URL (used for CORS — set to your actual domain)
FRONTEND_URL=https://makoy.org

# Session secret — used to sign OTP verification tokens and CSRF tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production. If unset, a random secret is generated per restart
# (invalidating all existing verification tokens on each server restart).
SESSION_SECRET=replace_with_a_random_64_char_hex_string

# ─── Hostinger SMTP (Email) ───────────────────────
# Hostinger email settings for team@makoy.org
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=team@makoy.org
SMTP_PASS=your_email_password_here

# ─── Hostinger MySQL (Database) ───────────────────
# Found in hPanel → Databases → MySQL Databases → Remote MySQL
# Enable remote access and use the hostname shown there
DB_HOST=your_hostinger_mysql_host
DB_PORT=3306
DB_USER=your_db_username
DB_PASS=your_db_password
DB_NAME=your_db_name

# ─────────────────────────────────────────────────
# Notes:
#   SMTP
#     - SMTP_PORT 465 = SSL (recommended for Hostinger)
#     - SMTP_PORT 587 = TLS (alternative)
#     - Never commit the actual .env file to git
#     - SMTP_PASS is your Hostinger email account password
#
#   MySQL (Hostinger)
#     - hPanel → Databases → MySQL Databases → Remote MySQL
#     - Add your OCI VPS IP to the allowed remote hosts list
#     - DB_HOST is the hostname shown in hPanel (e.g. srv1234.hstgr.io)
#     - The leads table is created automatically on first start
#
#   Marketing leads table columns (for reference):
#     email (PK), first_name, last_name, company, company_size,
#     industry, job_title, country, hr_challenge, notes,
#     phone, linkedin_url, source, utm_source, utm_medium,
#     utm_campaign, email_verified, opted_in_at, verified_at,
#     consulted_at, opted_out_at, created_at, updated_at
# ─────────────────────────────────────────────────
